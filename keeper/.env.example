# Operator = pemilik PredictManager (yang menandatangani open/settle hedge). Format suiprivkey1...
OPERATOR_PRIVATE_KEY=suiprivkey1...
# Alamat objek hasil deploy Jaga
JAGA_PKG=0x...
JAGA_VAULT=0x...
JAGA_KEEPER_CAP=0x...
JAGA_MANAGER=0x...
# Kebijakan hedge: strike OTM-down = forward*(1-pct); keeper otomatis melangkah ke strike
# quotable terdalam bila terlalu deep untuk expiry pendek.
HEDGE_STRIKE_DOWN_PCT=0.08
POLL_MS=15000
DRY_RUN=true
